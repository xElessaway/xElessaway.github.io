---
import { getCollection } from "astro:content";
import CTFAnswerValidator from "../../../components/CTFAnswerValidator.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const challenges = await getCollection("ctfChallenges");

  return challenges.map((entry) => ({
    params: {
      collection: entry.data.collection,
      challenge: entry.slug
    },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const collections = await getCollection("ctfCollections");
const collection = collections.find((item) => item.slug === entry.data.collection);
---

<BaseLayout title={`${entry.data.title} | ${collection?.data.title ?? "CTFs/Practice"}`} description={entry.data.prompt}>
  <section class="ctf-hero">
    <div class="container container-fluid">
      <article class="panel ctf-hero-panel">
        <div class="ops-meta-strip">
          <a class="meta-chip" href="/ctf/">ctfs/practice</a>
          {collection && <a class="meta-chip" href={`/ctf/${collection.slug}/`}>{collection.data.title}</a>}
          <span class:list={["difficulty-pill", entry.data.difficulty]}>{entry.data.difficulty}</span>
        </div>
        <p class="eyebrow">Practice Brief</p>
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.prompt}</p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container container-fluid stack">
      <article class="content-panel prose challenge-panel-simple">
        <p class="eyebrow">Challenge Brief</p>
        <p>{entry.data.prompt}</p>
        <p>
          Recover the expected answer string, match the required format, and validate locally before using it
          as the archive password or final answer key.
        </p>

        {
          entry.data.image && (
            <figure class="challenge-figure">
              <img src={entry.data.image} alt={entry.data.title} class="challenge-image" />
            </figure>
          )
        }

        {
          entry.data.assets.length > 0 && (
            <div class="challenge-assets-block">
              <p class="eyebrow">Challenge Assets</p>
              <div class="asset-list">
                {entry.data.assets.map((asset) => (
                  <a href={asset.url} target={asset.kind === "external" ? "_blank" : undefined} rel="noreferrer">
                    {asset.label}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </article>

      <div class="challenge-validator-inline">
        <CTFAnswerValidator
          collection={entry.data.collection}
          challenge={entry.slug}
          difficulty={entry.data.difficulty}
          passwordFormat={entry.data.passwordFormat}
          answerHashes={entry.data.answerHashes}
          hint={entry.data.hint}
        />
      </div>

      <article class="content-panel challenge-endnotes">
        <p class="eyebrow">Challenge Details</p>
        <dl class="story-meta-grid">
          <div>
            <dt>Practice Set</dt>
            <dd>{collection?.data.title ?? entry.data.collection}</dd>
          </div>
          <div>
            <dt>Difficulty</dt>
            <dd>{entry.data.difficulty}</dd>
          </div>
          <div>
            <dt>Password Format</dt>
            <dd class="mono">{entry.data.passwordFormat}</dd>
          </div>
          <div>
            <dt>Assets</dt>
            <dd>{entry.data.assets.length} linked file(s)</dd>
          </div>
        </dl>
      </article>
    </div>
  </section>
</BaseLayout>
