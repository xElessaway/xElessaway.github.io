---
import { getCollection } from "astro:content";
import CTFAnswerValidator from "../../../components/CTFAnswerValidator.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const challenges = await getCollection("ctfChallenges");

  return challenges.map((entry) => ({
    params: {
      collection: entry.data.collection,
      challenge: entry.slug
    },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const collections = await getCollection("ctfCollections");
const collection = collections.find((item) => item.slug === entry.data.collection);
const challengeImage = entry.data.image ?? entry.data.assets.find((asset) => asset.kind === "image")?.url;
const flagArchive = entry.data.assets.find(
  (asset) => asset.kind === "archive" || asset.label.toLowerCase().includes("flag archive")
);
---

<BaseLayout title={`${entry.data.title} | ${collection?.data.title ?? "CTFs/Practice"}`} description={entry.data.prompt}>
  <section class="ctf-hero">
    <div class="container">
      <article class="panel ctf-hero-panel">
        <div class="ops-meta-strip">
          <a class="meta-chip" href="/ctf/">ctfs/practice</a>
          {collection && <a class="meta-chip" href={`/ctf/${collection.slug}/`}>{collection.data.title}</a>}
          <span class:list={["difficulty-pill", entry.data.difficulty]}>{entry.data.difficulty}</span>
        </div>
        <p class="eyebrow">Practice Brief</p>
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.prompt}</p>
        {
          challengeImage && (
            <figure class="challenge-brief-figure">
              <img src={challengeImage} alt={entry.data.title} class="challenge-image" data-zoomable-image />
            </figure>
          )
        }
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container stack">
      <article class="content-panel challenge-summary-strip">
        <div class="challenge-summary-meta">
          <div>
            <span class="challenge-summary-label">Practice Set</span>
            <strong>{collection?.data.title ?? entry.data.collection}</strong>
          </div>
          <div>
            <span class="challenge-summary-label">Difficulty</span>
            <strong class="challenge-summary-value">{entry.data.difficulty}</strong>
          </div>
          <div>
            <span class="challenge-summary-label">Archive</span>
            {
              flagArchive ? (
                <a class="challenge-archive-link" href={flagArchive.url}>
                  {flagArchive.label}
                </a>
              ) : (
                <strong class="challenge-summary-value">No archive</strong>
              )
            }
          </div>
        </div>
      </article>

      <div class="challenge-validator-inline">
        <CTFAnswerValidator
          collection={entry.data.collection}
          challenge={entry.slug}
          passwordFormat={entry.data.passwordFormat}
          answerHashes={entry.data.answerHashes}
          hint={entry.data.hint}
        />
      </div>
    </div>
  </section>
</BaseLayout>
