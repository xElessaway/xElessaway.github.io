---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const collections = await getCollection("ctfCollections");
const challenges = await getCollection("ctfChallenges");

const stats = collections.map((entry) => {
  const collectionChallenges = challenges.filter((challenge) => challenge.data.collection === entry.slug);
  const easy = collectionChallenges.filter((challenge) => challenge.data.difficulty === "easy").length;
  const medium = collectionChallenges.filter((challenge) => challenge.data.difficulty === "medium").length;
  const hard = collectionChallenges.filter((challenge) => challenge.data.difficulty === "hard").length;

  return {
    entry,
    total: collectionChallenges.length,
    easy,
    medium,
    hard
  };
});
---

<BaseLayout title="CTFs/Practice | Ahmed Elessaway (xElessaway)" description="CTF collections and practice routes with simplified validation.">
  <section class="ctf-hero">
    <div class="container">
      <article class="panel ctf-hero-panel">
        <div class="ops-meta-strip">
          <span class="meta-chip">ctfs_practice // collections</span>
          <span class="meta-chip">{collections.length} collections</span>
          <span class="meta-chip">{challenges.length} challenge nodes</span>
        </div>
        <p class="eyebrow">CTFs/Practice</p>
        <h1>Hands-on practice collections for DFIR and OSINT workflows.</h1>
        <p class="lede">
          Collection discovery happens at the archive level. Every collection has its own route, every
          challenge gets a dedicated mission page, and answer checks remain lightweight enough for GitHub
          Pages.
        </p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container card-grid">
      {
        stats.map(({ entry, total, easy, medium, hard }) => (
          <a class="challenge-card" href={`/ctf/${entry.slug}/`}>
            <div class="status-row">
              <span class:list={["status-pill", entry.data.status]}>{entry.data.status}</span>
              <span class="meta-chip">{entry.data.year}</span>
            </div>
            <p class="eyebrow">practice_set</p>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
            <div class="tag-list">
              <span class="difficulty-pill easy">{easy} easy</span>
              <span class="difficulty-pill medium">{medium} medium</span>
              <span class="difficulty-pill hard">{hard} hard</span>
            </div>
            <div class="meta-line">
              <span>{total} challenge(s)</span>
              <span>github_backed_assets</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
