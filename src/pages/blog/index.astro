---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout
  title="Blog | Ahmed Elessaway (xElessaway)"
  description="Research briefs, DFIR writeups, OSINT investigations, and threat-focused technical notes."
>
  <section class="page-intro">
    <div class="container">
      <article class="panel page-intro-panel">
        <p class="eyebrow">Blog</p>
        <h1>Research briefs and technical writeups.</h1>
        <p class="lede">
          DFIR investigations, OSINT analysis, challenge writeups, and threat-focused notes collected in one
          place so they remain searchable, linkable, and reusable.
        </p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container card-grid">
      {
        posts.map((post) => (
          <a class="story-card" href={`/blog/${post.slug}/`}>
            <div class="card-topline">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div class="meta-line">
              <span>{post.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
              <span>{post.data.featured ? "Featured" : post.data.sourceLabel ?? "Research Brief"}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
