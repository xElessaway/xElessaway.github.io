---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const reports = posts.filter((post) => post.data.archiveSection === "reports");
const writeups = posts.filter((post) => post.data.archiveSection === "writeups");

const getSectionFilters = (entries: typeof posts) =>
  [...entries.reduce((acc, post) => {
    post.data.tags.forEach((tag) => {
      acc.set(tag, (acc.get(tag) ?? 0) + 1);
    });

    return acc;
  }, new Map<string, number>()).entries()]
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .map(([tag, count]) => ({ tag, count }));

const archiveSections = [
  { id: "reports", label: "Reports", posts: reports, filters: getSectionFilters(reports) },
  { id: "writeups", label: "Writeups", posts: writeups, filters: getSectionFilters(writeups) }
];
---

<BaseLayout
  title="Blog | Ahmed Elessaway (xElessaway)"
  description="Reports and writeups covering DFIR investigations, OSINT analysis, technical walkthroughs, and threat-focused notes."
>
  <section class="page-intro">
    <div class="container">
      <article class="panel page-intro-panel">
        <div class="ops-meta-strip">
          <span class="meta-chip">{reports.length} reports</span>
          <span class="meta-chip">{writeups.length} writeups</span>
        </div>
        <p class="eyebrow">Archive</p>
        <h1>Reports and writeups, split cleanly.</h1>
        <p class="lede">
          Real-world reports and technical walkthroughs live in the same archive, but each type now has its
          own cleaner lane.
        </p>

        <div class="archive-switch" role="tablist" aria-label="Archive sections">
          {
            archiveSections.map((section, index) => (
              <button
                class:list={["archive-trigger", index === 0 && "is-active"]}
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                data-archive-trigger={section.id}
              >
                <span>{section.label}</span>
                <span class="archive-count">{section.posts.length}</span>
              </button>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container stack">
      {
        archiveSections.map((section, index) => {
          return (
            <div class:list={["archive-panel", index === 0 && "is-visible"]} data-archive-panel={section.id} hidden={index !== 0}>
              {
                section.posts.length > 0 ? (
                  <>
                    <div class="archive-toolbar">
                      <div class="archive-filters" aria-label={`${section.label} filters`}>
                        <button
                          class="archive-filter is-active"
                          type="button"
                          data-archive-filter={section.id}
                          data-tag="all"
                        >
                          <span>All</span>
                          <span class="archive-count">{section.posts.length}</span>
                        </button>

                        {
                          section.filters.map((filter) => (
                            <button
                              class="archive-filter"
                              type="button"
                              data-archive-filter={section.id}
                              data-tag={filter.tag}
                            >
                              <span>{filter.tag}</span>
                              <span class="archive-count">{filter.count}</span>
                            </button>
                          ))
                        }
                      </div>
                    </div>

                    <div class="archive-results" data-archive-results={section.id}>
                      {
                        section.posts.map((post, postIndex) => (
                          <a
                            class:list={["story-card", "story-card-report", "archive-entry", postIndex === 0 && "is-lead"]}
                            href={`/blog/${post.slug}/`}
                            data-archive-entry={section.id}
                            data-tags={post.data.tags.join("|")}
                          >
                            {post.data.cover && (
                              <div class="card-media">
                                <img src={post.data.cover} alt={post.data.title} loading="lazy" />
                              </div>
                            )}

                            <div class="archive-entry-copy">
                              <div class="card-topline">
                                <span class="meta-chip">{post.data.archiveSection}</span>
                                {post.data.tags.slice(0, postIndex === 0 ? 3 : 2).map((tag) => <span class="tag">{tag}</span>)}
                              </div>

                              <p class="eyebrow archive-entry-kicker">Lead {section.label.slice(0, -1)}</p>
                              <h3>{post.data.title}</h3>
                              <p>{post.data.description}</p>
                              <div class="meta-line">
                                <span>
                                  {post.data.publishedAt.toLocaleDateString("en-US", {
                                    dateStyle: postIndex === 0 ? "long" : "medium"
                                  })}
                                </span>
                                <span>{postIndex === 0 ? post.data.sourceLabel ?? "Research Brief" : post.data.featured ? "featured" : "indexed"}</span>
                              </div>
                            </div>
                          </a>
                        ))
                      }
                    </div>

                    <article class="content-panel archive-empty" data-archive-empty={section.id} hidden>
                      <p>No {section.label.toLowerCase()} match this filter.</p>
                    </article>
                  </>
                ) : (
                  <article class="content-panel archive-empty">
                    <p>No {section.label.toLowerCase()} are published yet.</p>
                  </article>
                )
              }
            </div>
          );
        })
      }
    </div>
  </section>

  <script>
    const archiveButtons = [...document.querySelectorAll("[data-archive-trigger]")];
    const archivePanels = [...document.querySelectorAll("[data-archive-panel]")];
    const archiveFilters = [...document.querySelectorAll("[data-archive-filter]")];
    const archiveResults = [...document.querySelectorAll("[data-archive-results]")];
    const archiveEmptyStates = [...document.querySelectorAll("[data-archive-empty]")];

    const applySectionFilter = (sectionId: string, activeTag: string) => {
      const activeFilters = archiveFilters.filter(
        (filter) => filter.getAttribute("data-archive-filter") === sectionId
      );
      const entries = [...document.querySelectorAll(`[data-archive-entry="${sectionId}"]`)];
      const emptyState = archiveEmptyStates.find(
        (state) => state.getAttribute("data-archive-empty") === sectionId
      );

      activeFilters.forEach((filter) => {
        const isActive = filter.getAttribute("data-tag") === activeTag;
        filter.classList.toggle("is-active", isActive);
        filter.setAttribute("aria-pressed", String(isActive));
      });

      const visibleEntries = entries.filter((entry) => {
        const tags = (entry.getAttribute("data-tags") ?? "").split("|").filter(Boolean);
        const isVisible = activeTag === "all" || tags.includes(activeTag);
        entry.toggleAttribute("hidden", !isVisible);
        entry.classList.remove("is-lead");
        return isVisible;
      });

      const firstVisible = visibleEntries[0];

      if (firstVisible) {
        firstVisible.classList.add("is-lead");
      }

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleEntries.length > 0;
      }
    };

    const applyArchiveState = (activeId: string) => {
      archiveButtons.forEach((button) => {
        const isActive = button.getAttribute("data-archive-trigger") === activeId;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
      });

      archivePanels.forEach((panel) => {
        const isActive = panel.getAttribute("data-archive-panel") === activeId;
        panel.toggleAttribute("hidden", !isActive);
        panel.classList.toggle("is-visible", isActive);
      });

      if (window.location.hash !== `#${activeId}`) {
        window.history.replaceState({}, "", `#${activeId}`);
      }
    };

    archiveButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const next = button.getAttribute("data-archive-trigger") ?? "reports";
        applyArchiveState(next);
      });
    });

    archiveFilters.forEach((filter) => {
      filter.addEventListener("click", () => {
        const sectionId = filter.getAttribute("data-archive-filter");
        const activeTag = filter.getAttribute("data-tag") ?? "all";

        if (sectionId) {
          applySectionFilter(sectionId, activeTag);
        }
      });
    });

    archiveResults.forEach((resultSet) => {
      const sectionId = resultSet.getAttribute("data-archive-results");

      if (sectionId) {
        applySectionFilter(sectionId, "all");
      }
    });

    const initialArchive = window.location.hash.replace("#", "");
    const isKnownArchive = archivePanels.some((panel) => panel.getAttribute("data-archive-panel") === initialArchive);
    applyArchiveState(isKnownArchive ? initialArchive : "reports");

    window.addEventListener("hashchange", () => {
      const nextArchive = window.location.hash.replace("#", "");

      if (archivePanels.some((panel) => panel.getAttribute("data-archive-panel") === nextArchive)) {
        applyArchiveState(nextArchive);
      }
    });
  </script>
</BaseLayout>
