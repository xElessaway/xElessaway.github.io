---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const archiveLabel = entry.data.archiveSection === "reports" ? "Report" : "Writeup";
const formatLabel = entry.data.sourceLabel === "Medium" ? "Imported Medium entry" : "Research brief";
---

<BaseLayout title={`${entry.data.title} | Ahmed Elessaway`} description={entry.data.description}>
  <section class="story-hero">
    <div class="container container-fluid">
      <article class="panel story-hero-panel story-hero-panel-simple">
        <div class="ops-meta-strip">
          <span class="meta-chip">{entry.data.archiveSection}</span>
          <span class="meta-chip">{entry.data.sourceLabel ?? "Research Brief"}</span>
          <span class="meta-chip">{entry.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
        </div>
        <p class="eyebrow">{archiveLabel}</p>
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.description}</p>
        <div class="meta-line">
          {entry.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container container-fluid">
      <article class="content-panel prose story-panel story-panel-simple">
        <Content />

        <footer class="story-endnotes">
          <p class="eyebrow">Entry Details</p>
          <dl class="story-meta-grid">
            <div>
              <dt>Published</dt>
              <dd>{entry.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "long" })}</dd>
            </div>
            <div>
              <dt>Type</dt>
              <dd>{archiveLabel}</dd>
            </div>
            <div>
              <dt>Format</dt>
              <dd>{formatLabel}</dd>
            </div>
            <div>
              <dt>Tags</dt>
              <dd>{entry.data.tags.join(", ")}</dd>
            </div>
            {
              entry.data.sourceUrl && (
                <div class="story-meta-wide">
                  <dt>Original Source</dt>
                  <dd>
                    <a href={entry.data.sourceUrl} target="_blank" rel="noreferrer">
                      {entry.data.sourceLabel ?? "External source"}
                    </a>
                  </dd>
                </div>
              )
            }
          </dl>
        </footer>
      </article>
    </div>
  </section>
</BaseLayout>
