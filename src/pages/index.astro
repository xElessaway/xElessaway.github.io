---
import { getCollection } from "astro:content";
import { readdir } from "node:fs/promises";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { siteMeta } from "../data/site";

const actorDirEntries = await readdir(new URL("../content/actors", import.meta.url), { withFileTypes: true }).catch(() => []);
const hasActorEntries = actorDirEntries.some(
  (entry) => entry.isFile() && entry.name.endsWith(".md") && !entry.name.startsWith("_")
);

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const recentPosts = blogPosts.slice(0, 3);

const actorCount = hasActorEntries ? (await getCollection("actors")).length : 0;
const collections = await getCollection("ctfCollections");
const featuredCollection = collections.find((entry) => entry.data.featured) ?? collections[0];

const missionMetrics = [
  { value: "3+", label: "Years in cyber engineering" },
  { value: "200+", label: "Learners trained hands-on" },
  { value: String(blogPosts.length), label: "Public reports and writeups" }
];

const entryPoints = [
  {
    eyebrow: "Reports",
    title: "Technical reports and writeups",
    description: "The main archive for investigations, walkthroughs, and practical security notes.",
    href: "/blog/",
    action: "Open Archive",
    meta: `${blogPosts.length} published`
  },
  {
    eyebrow: "Threat Intelligence",
    title: actorCount > 0 ? "Published dossiers and actor tracking" : "Threat intel framework ready",
    description:
      actorCount > 0
        ? "Structured actor pages with timelines, TTP mapping, tooling, and references."
        : "The structure is ready for real dossiers without filling the homepage with placeholder intel.",
    href: "/threat-intelligence/",
    action: "Open Threat Intel",
    meta: `${actorCount} public dossiers`
  },
  {
    eyebrow: "Training",
    title: "CTFs and analyst labs",
    description: "Challenge pages stay simple, with one clear validation flow and repeatable training structure.",
    href: featuredCollection ? `/ctf/${featuredCollection.slug}/` : "/ctf/",
    action: "Open Training",
    meta: featuredCollection?.data.title ?? "Training surface"
  }
];
---

<BaseLayout title={`${siteMeta.title} | DFIR, OSINT, Threat Intelligence`} description={siteMeta.description}>
  <section class="home-hero">
    <div class="container stack">
      <article class="panel hero-panel hero-panel-primary home-hero-simple">
        <div class="ops-meta-strip">
          <span class="meta-chip">dfir</span>
          <span class="meta-chip">osint</span>
          <span class="meta-chip">threat_intelligence</span>
        </div>

        <p class="eyebrow">Home</p>
        <h1>DFIR, OSINT, and threat intelligence.</h1>
        <p class="lede">
          A simple landing page for investigations, research notes, threat tracking, and practical training
          content.
        </p>

        <div class="tag-list home-focus-tags">
          <span class="tag">Investigations</span>
          <span class="tag">Writeups</span>
          <span class="tag">Threat Tracking</span>
          <span class="tag">Training Labs</span>
        </div>

        <div class="button-row">
          <a class="button button-primary" href="/blog/">Open Reports</a>
          <a class="button button-ghost" href="/ctf/">Open Training</a>
          <a class="button button-ghost" href="/about/">View Profile</a>
        </div>

        <div class="stats-grid">
          {
            missionMetrics.map((item) => (
              <div class="stat-block">
                <strong>{item.value}</strong>
                <span>{item.label}</span>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <SectionHeader
        eyebrow="Recent Reports"
        title="Latest published work"
        description="The most recent public reports and technical writeups."
        actionHref="/blog/"
        actionLabel="View Archive"
      />

      <div class="card-grid">
        {
          recentPosts.map((post) => (
            <a class="story-card story-card-report" href={`/blog/${post.slug}/`}>
              {post.data.cover && (
                <div class="card-media">
                  <img src={post.data.cover} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="card-topline">
                <span class="meta-chip">{post.data.archiveSection}</span>
                {post.data.tags.slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="meta-line">
                <span>{post.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
                <span>{post.data.featured ? "priority_brief" : "indexed"}</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <SectionHeader
        eyebrow="Explore"
        title="Three clear entry points"
        description="Everything important stays behind the archive, the threat intel section, and the training surface."
      />

      <div class="home-surface-grid">
        {
          entryPoints.map((entry) => (
            <a class="intel-link home-surface-card" href={entry.href}>
              <p class="eyebrow">{entry.eyebrow}</p>
              <h3>{entry.title}</h3>
              <p>{entry.description}</p>
              <div class="meta-line">
                <span>{entry.meta}</span>
                <span>{entry.action}</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
