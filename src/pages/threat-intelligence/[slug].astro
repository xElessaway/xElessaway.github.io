---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const actors = await getCollection("actors");

  return actors.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = allPosts.filter((post) => entry.data.relatedPosts.includes(post.slug));
---

<BaseLayout title={`${entry.data.name} | Threat Intelligence`} description={entry.data.motivation}>
  <section class="dossier-hero">
    <div class="container">
      <article class="panel dossier-hero-panel">
        <div class="status-row">
          <span class:list={["status-pill", entry.data.status]}>{entry.data.status}</span>
          <span class="meta-chip">{entry.data.origin}</span>
          <span class="meta-chip">First seen {entry.data.firstSeen}</span>
          <span class="meta-chip">Last seen {entry.data.lastSeen}</span>
        </div>
        <h1 style="margin-top: 1rem;">{entry.data.name}</h1>
        <p class="lede">{entry.data.motivation}</p>
        {entry.data.aliases.length > 0 && <p class="muted-copy" style="margin-top: 1rem;">Aliases: {entry.data.aliases.join(", ")}</p>}
        <div class="tag-list" style="margin-top: 1rem;">
          {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container content-layout">
      <article class="stack">
        <div class="content-panel prose">
          <h2>Executive Summary</h2>
          <Content />
        </div>

        {entry.data.timeline.length > 0 && (
          <div class="content-panel">
            <h2 style="margin-bottom: 1rem;">Timeline</h2>
            <div class="timeline">
              {entry.data.timeline.map((item) => (
                <article class="timeline-item">
                  <time>{item.date}</time>
                  <h3>{item.title}</h3>
                  <p class="muted-copy" style="margin-top: 0.7rem;">{item.summary}</p>
                </article>
              ))}
            </div>
          </div>
        )}

        {entry.data.ttps.length > 0 && (
          <div class="content-panel">
            <h2 style="margin-bottom: 1rem;">Observed TTP Themes</h2>
            <div class="tag-list">
              {entry.data.ttps.map((ttp) => <span class="tag">{ttp}</span>)}
            </div>
          </div>
        )}

        {entry.data.references.length > 0 && (
          <div class="content-panel">
            <h2 style="margin-bottom: 1rem;">References</h2>
            <div class="stack">
              {entry.data.references.map((reference) => (
                <a class="story-card" href={reference.url} target="_blank" rel="noreferrer">
                  <h3>{reference.title}</h3>
                  <p>{reference.publisher ?? "External source"}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>

      <aside class="stack">
        <div class="meta-card">
          <p class="eyebrow">Quick Facts</p>
          <dl>
            <div>
              <dt>Status</dt>
              <dd>{entry.data.status}</dd>
            </div>
            <div>
              <dt>Origin</dt>
              <dd>{entry.data.origin}</dd>
            </div>
            <div>
              <dt>Motivation</dt>
              <dd>{entry.data.motivation}</dd>
            </div>
            <div>
              <dt>Targets</dt>
              <dd>{entry.data.targets.join(", ")}</dd>
            </div>
          </dl>
        </div>

        {entry.data.tools.length > 0 && (
          <div class="meta-card">
            <p class="eyebrow">Tooling / Malware</p>
            <div class="tag-list">
              {entry.data.tools.map((tool) => <span class="tag">{tool}</span>)}
            </div>
          </div>
        )}

        {relatedPosts.length > 0 && (
          <div class="meta-card">
            <p class="eyebrow">Related Posts</p>
            <div class="stack">
              {relatedPosts.map((post) => (
                <a href={`/blog/${post.slug}/`}>
                  <strong>{post.data.title}</strong>
                  <p class="muted-copy" style="margin-top: 0.35rem;">{post.data.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
