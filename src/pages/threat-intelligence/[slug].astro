---
import { getCollection, render } from "astro:content";
import { readdir } from "node:fs/promises";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const actorDirEntries = await readdir(new URL("../../content/actors", import.meta.url), { withFileTypes: true }).catch(() => []);
  const hasActorEntries = actorDirEntries.some(
    (entry) => entry.isFile() && entry.name.endsWith(".md") && !entry.name.startsWith("_")
  );

  if (!hasActorEntries) {
    return [];
  }

  const actors = await getCollection("actors");

  return actors.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = allPosts.filter((post) => entry.data.relatedPosts.includes(post.slug));
---

<BaseLayout title={`${entry.data.name} | Threat Intel`} description={entry.data.motivation}>
  <section class="dossier-hero">
    <div class="container">
      <article class="panel dossier-hero-panel">
        <div class="ops-meta-strip">
          <span class:list={["status-pill", entry.data.status]}>{entry.data.status}</span>
          <span class="meta-chip">{entry.data.origin}</span>
          <span class="meta-chip">first_seen {entry.data.firstSeen}</span>
          <span class="meta-chip">last_seen {entry.data.lastSeen}</span>
        </div>
        <p class="eyebrow">Threat Intel Dossier</p>
        <h1>{entry.data.name}</h1>
        <p class="lede">{entry.data.motivation}</p>
        {entry.data.aliases.length > 0 && (
          <div class="tag-list">
            {entry.data.aliases.map((alias) => <span class="tag">{alias}</span>)}
          </div>
        )}
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container dossier-layout">
      <article class="stack">
        <div class="content-panel prose">
          <p class="eyebrow">Executive Summary</p>
          <Content />
        </div>

        <div class="detail-grid dossier-grid">
          <div class="meta-card">
            <p class="eyebrow">Identity Profile</p>
            <dl class="fact-grid">
              <div>
                <dt>Primary Name</dt>
                <dd>{entry.data.name}</dd>
              </div>
              <div>
                <dt>Origin</dt>
                <dd>{entry.data.origin}</dd>
              </div>
              <div>
                <dt>Status</dt>
                <dd>{entry.data.status}</dd>
              </div>
              <div>
                <dt>Motivation</dt>
                <dd>{entry.data.motivation}</dd>
              </div>
            </dl>
          </div>

          {entry.data.ttps.length > 0 && (
            <div class="content-panel">
              <p class="eyebrow">Observed TTP Themes</p>
              <div class="ttp-list">
                {entry.data.ttps.map((ttp, index) => (
                  <div class="ttp-row">
                    <span class="ttp-index mono">TTP_{String(index + 1).padStart(2, "0")}</span>
                    <p>{ttp}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        {entry.data.timeline.length > 0 && (
          <div class="content-panel">
            <p class="eyebrow">Operational Timeline</p>
            <div class="timeline">
              {entry.data.timeline.map((item) => (
                <article class="timeline-item">
                  <time>{item.date}</time>
                  <h3>{item.title}</h3>
                  <p class="muted-copy">{item.summary}</p>
                </article>
              ))}
            </div>
          </div>
        )}

        {entry.data.references.length > 0 && (
          <div class="content-panel">
            <p class="eyebrow">References</p>
            <div class="stack">
              {entry.data.references.map((reference) => (
                <a class="story-card" href={reference.url} target="_blank" rel="noreferrer">
                  <div class="card-topline">
                    <span class="meta-chip">{reference.publisher ?? "external_source"}</span>
                  </div>
                  <h3>{reference.title}</h3>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>

      <aside class="stack">
        <div class="meta-card">
          <p class="eyebrow">Target Surface</p>
          <div class="tag-list">
            {entry.data.targets.map((target) => <span class="tag">{target}</span>)}
          </div>
        </div>

        {entry.data.tools.length > 0 && (
          <div class="meta-card">
            <p class="eyebrow">Tooling / Malware</p>
            <div class="tag-list">
              {entry.data.tools.map((tool) => <span class="tag">{tool}</span>)}
            </div>
          </div>
        )}

        <div class="meta-card">
          <p class="eyebrow">Quick Facts</p>
          <dl>
            <div>
              <dt>Aliases</dt>
              <dd>{entry.data.aliases.join(", ") || "None listed"}</dd>
            </div>
            <div>
              <dt>Targets</dt>
              <dd>{entry.data.targets.join(", ")}</dd>
            </div>
            <div>
              <dt>First Seen</dt>
              <dd>{entry.data.firstSeen}</dd>
            </div>
            <div>
              <dt>Last Seen</dt>
              <dd>{entry.data.lastSeen}</dd>
            </div>
          </dl>
        </div>

        {relatedPosts.length > 0 && (
          <div class="meta-card">
            <p class="eyebrow">Related Reports</p>
            <div class="stack">
              {relatedPosts.map((post) => (
                <a href={`/blog/${post.slug}/`}>
                  <strong>{post.data.title}</strong>
                  <p class="muted-copy">{post.data.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
