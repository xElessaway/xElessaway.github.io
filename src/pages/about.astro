---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/site";

const certifications = [
  "Certified Incident Responder (eCIRv2) - INE Security",
  "Cloud Red Team Tactics for Attacking & Defending Azure (CARTP) - AlteredSecurity",
  "Certified Cyber Defender (CCD) - CyberDefenders",
  "Open-Source Intelligence - Basel Institute on Governance",
  "Threat Intelligence Analyst 101 - ArcX"
];

const experience = [
  {
    period: "Dec 2024 - Present",
    title: "CyberDefenders - Cyber Security Engineer",
    summary:
      "Blue-team lab environments, threat-hunting scenarios, CCD curriculum, DFIR teaching modules, and practical Windows/Linux evidence analysis."
  },
  {
    period: "Mar 2023 - Present",
    title: "CyberTalents - Engineer / Instructor",
    summary:
      "Forensics, OSINT, and network-security challenge creation; hands-on training delivery; and operational support for live CTF environments."
  },
  {
    period: "Nov 2023 - Jun 2024",
    title: "LetsDefend Labs - DFIR Lab Creator",
    summary:
      "Realistic disk and memory-forensics labs with guided write-ups to increase analyst confidence and investigation quality."
  },
  {
    period: "2020 - Present",
    title: "0xL4ugh - CTF Development and Author",
    summary:
      "Recurring DFIR, OSINT, steganography, and network-security challenge authoring for public events and custom competitions."
  }
];
---

<BaseLayout title="About | Ahmed Elessaway (xElessaway)" description="Threat Intelligence and DFIR-focused cybersecurity engineer.">
  <section class="about-hero">
    <div class="container">
      <article class="panel about-hero-panel">
        <p class="eyebrow">About</p>
        <h1>Threat Intelligence and DFIR-focused cybersecurity engineer.</h1>
        <p class="lede">
          Ahmed Elessaway works across blue-team lab development, threat-hunting scenarios, digital forensics,
          OSINT training, and intelligence-led security content. The site is designed to reflect that
          operating profile directly.
        </p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container split-grid">
      <article class="content-panel prose">
        <h2>Summary</h2>
        <p>
          The core of the profile is not generic content publishing. It is investigation-driven work: blue-team
          simulations, incident-analysis training, memory and disk forensics, threat-intelligence context, and
          OSINT workflows that support real analyst development.
        </p>
        <p>
          That is why the site should feel closer to a cyber operations surface than a university journal.
          Research, dossiers, and challenge content all stay, but they now sit under a stronger DFIR and threat
          operations identity.
        </p>

        <h2>Current Focus</h2>
        <ul>
          <li>Threat-hunting and detection scenarios for blue-team readiness.</li>
          <li>Windows and Linux evidence collection with memory and disk forensics.</li>
          <li>OSINT and threat-intelligence fundamentals that improve investigation context.</li>
          <li>Hands-on labs, CTFs, and analyst-focused technical training.</li>
        </ul>

        <h2>Experience Highlights</h2>
        <div class="role-grid">
          {
            experience.map((item) => (
              <article class="role-card">
                <p class="role-period">{item.period}</p>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>

        <h2>Competition and Community Signal</h2>
        <ul>
          <li>2nd place in CyCTF'25 Finals and Arab Cyberwar Games Championship.</li>
          <li>4th place in EG-CERT CTF Finals and CSC-1 (ICMTC) Finals.</li>
          <li>Hands-on instruction delivered to more than 200 attendees across multiple topics.</li>
          <li>OSINT Essentials instruction delivered at ITI for younger learners through practical exercises.</li>
        </ul>
      </article>

      <aside class="stack">
        <div class="meta-card">
          <p class="eyebrow">Profile Snapshot</p>
          <dl>
            <div>
              <dt>Name</dt>
              <dd>Ahmed Elessaway</dd>
            </div>
            <div>
              <dt>Handle</dt>
              <dd>xElessaway</dd>
            </div>
            <div>
              <dt>Location</dt>
              <dd>{siteMeta.location}</dd>
            </div>
            <div>
              <dt>Primary Domains</dt>
              <dd>DFIR, Threat Intelligence, OSINT, Threat Hunting</dd>
            </div>
          </dl>
        </div>

        <div class="meta-card">
          <p class="eyebrow">Certifications</p>
          <div class="stack">
            {
              certifications.map((item) => (
                <div class="intel-link">
                  <strong>{item}</strong>
                </div>
              ))
            }
          </div>
        </div>

        <div class="meta-card">
          <p class="eyebrow">Tool Stack</p>
          <div class="tag-list">
            <span class="tag">OpenCTI</span>
            <span class="tag">Splunk</span>
            <span class="tag">ELK</span>
            <span class="tag">Sentinel</span>
            <span class="tag">Wireshark</span>
            <span class="tag">Autopsy</span>
            <span class="tag">PowerShell</span>
            <span class="tag">Python</span>
            <span class="tag">Linux</span>
            <span class="tag">Windows</span>
          </div>
        </div>

        <div class="meta-card">
          <p class="eyebrow">Contact / Presence</p>
          <div class="stack">
            {
              siteMeta.socials.map((item) => (
                <a href={item.href} target="_blank" rel="noreferrer">
                  <strong>{item.label}</strong>
                  <p class="muted-copy" style="margin-top: 0.25rem;">{item.href.replace("https://", "")}</p>
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
