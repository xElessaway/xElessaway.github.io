---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/site";

const focusAreas = [
  "Threat Hunting",
  "Detection Scenarios",
  "Memory Forensics",
  "Disk Forensics",
  "OSINT Workflows",
  "Blue-team Labs"
];

const achievementHighlights = [
  "2nd place in CyCTF'25 Finals and Arab Cyberwar Games Championship.",
  "4th place in EG-CERT CTF Finals and CSC-1 Finals.",
  "Hands-on instruction delivered to more than 200 attendees across multiple topics.",
  "Public training and challenge content focused on DFIR, OSINT, and analyst workflows."
];
---

<BaseLayout title="About | Ahmed Elessaway (xElessaway)" description="Threat Intelligence and DFIR-focused cybersecurity engineer.">
  <section class="about-hero">
    <div class="container">
      <article class="panel about-hero-panel">
        <div class="ops-meta-strip">
          <span class="meta-chip">operator_profile</span>
          <span class="meta-chip">dfir</span>
          <span class="meta-chip">osint</span>
          <span class="meta-chip">threat_intelligence</span>
        </div>
        <p class="eyebrow">Operator Profile</p>
        <h1>Threat Intelligence and DFIR-focused cybersecurity engineer.</h1>
        <p class="lede">
          Public profile centered on investigations, blue-team training systems, technical analysis, and
          archive-ready security writing.
        </p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="container split-grid">
      <article class="stack">
        <div class="content-panel prose">
          <p class="eyebrow">Summary</p>
          <p>
            The core of the profile is investigation-driven work: evidence handling, technical analysis,
            threat-intelligence context, OSINT workflows, and practical training material that stays useful for
            analysts.
          </p>
          <p>
            The site is built to reflect that operating profile directly. Reports, dossiers, and training
            content stay public, while personal and workplace details remain out of scope for the public
            surface.
          </p>
        </div>

        <div class="content-panel">
          <p class="eyebrow">Current Focus</p>
          <div class="tag-list">
            {focusAreas.map((item) => <span class="tag">{item}</span>)}
          </div>
        </div>

        <div class="content-panel prose">
          <p class="eyebrow">Competition and Community Signal</p>
          <ul>
            {achievementHighlights.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>

      <aside class="stack">
        <div class="meta-card">
          <p class="eyebrow">Profile Snapshot</p>
          <dl>
            <div>
              <dt>Name</dt>
              <dd>Ahmed Elessaway</dd>
            </div>
            <div>
              <dt>Handle</dt>
              <dd>xElessaway</dd>
            </div>
            <div>
              <dt>Primary Domains</dt>
              <dd>DFIR, Threat Intelligence, OSINT, Threat Hunting</dd>
            </div>
            <div>
              <dt>Public Focus</dt>
              <dd>Investigations, training systems, archive-quality research, and practical analyst workflows.</dd>
            </div>
          </dl>
        </div>

        <div class="meta-card">
          <p class="eyebrow">Media / Presence</p>
          <div class="stack">
            {
              siteMeta.socials.map((item) => (
                <a href={item.href} target="_blank" rel="noreferrer">
                  <strong>{item.label}</strong>
                  <p class="muted-copy">{item.href.replace("https://", "")}</p>
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
