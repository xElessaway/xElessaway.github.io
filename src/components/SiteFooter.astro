---
import { siteMeta } from "../data/site";
import { withBase } from "../utils/paths";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-kicker">Ahmed Elessaway (xElessaway)</p>
      <p class="footer-copy">
        Threat hunting labs, DFIR workflows, OSINT investigations, and threat-intelligence-driven content.
      </p>
    </div>

    <div class="footer-links">
      {
        siteMeta.nav.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))
      }
    </div>

    <div class="footer-links">
      {
        siteMeta.socials.map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))
      }
    </div>
  </div>
</footer>
