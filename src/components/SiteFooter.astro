---
import { siteMeta } from "../data/site";
import { withBase } from "../utils/paths";
---

<footer class="site-footer">
  <div class="container footer-grid footer-grid-compact">
    <div class="footer-links footer-links-inline">
      {
        siteMeta.nav.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))
      }
    </div>

    <div class="footer-links footer-links-inline footer-links-right">
      {
        siteMeta.socials.map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))
      }
    </div>
  </div>
</footer>
