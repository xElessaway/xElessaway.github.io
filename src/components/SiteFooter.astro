---
import { siteMeta } from "../data/site";
import { withBase } from "../utils/paths";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-kicker">system_status</p>
      <p class="footer-copy">
        Tactical intelligence surface for DFIR, OSINT, threat intelligence, and analyst-focused training.
      </p>
    </div>

    <div class="footer-links footer-links-inline">
      {
        siteMeta.nav.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))
      }
    </div>

    <div class="footer-links footer-links-inline">
      {
        siteMeta.socials.map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))
      }
    </div>
  </div>
</footer>
