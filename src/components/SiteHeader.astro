---
import { siteMeta } from "../data/site";
import { withBase } from "../utils/paths";

const pathname = Astro.url.pathname;
const moduleLabels: Record<string, { top: string; side: string; short: string }> = {
  "/": { top: "Dashboard", side: "Operator Surface", short: "HM" },
  "/blog/": { top: "Reports", side: "Investigation Archive", short: "RP" },
  "/threat-intelligence/": { top: "Threats", side: "Intel Dossiers", short: "TI" },
  "/ctf/": { top: "Training", side: "CTF Modules", short: "CTF" },
  "/about/": { top: "Profile", side: "Operator Profile", short: "AB" }
};
---

<header class="site-header">
  <div class="shell-bar">
    <div class="shell-left">
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-sidebar">
        <span class="sr-only">Toggle navigation</span>
        <span></span>
      </button>

      <a class="brand-mark" href={withBase("/")}>
        <span class="brand-signal" aria-hidden="true"></span>
        <span class="brand-copy">
          <strong>Ahmed Elessaway</strong>
          <small>xElessaway</small>
        </span>
      </a>
    </div>

    <nav id="site-nav" class="site-nav" aria-label="Primary navigation">
      {
        siteMeta.nav.map((item) => {
          const isActive = item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
          const labels = moduleLabels[item.href] ?? { top: item.label, side: item.label, short: item.label.slice(0, 2) };

          return (
            <a class:list={["nav-link", isActive && "is-active"]} href={withBase(item.href)}>
              {labels.top}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>

<div class="mobile-overlay" data-mobile-overlay hidden></div>

<aside id="site-sidebar" class="site-sidebar" aria-label="Section navigation">
  <div class="sidebar-rail-head">
    <span class="sidebar-rail-glyph" aria-hidden="true"></span>
    <p class="sidebar-rail-label">Navigation</p>
  </div>

  <nav class="side-nav">
    {
      siteMeta.nav.map((item, index) => {
        const isActive = item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
        const labels = moduleLabels[item.href] ?? { top: item.label, side: item.label, short: item.label.slice(0, 2) };

        return (
          <a class:list={["side-nav-link", isActive && "is-active"]} href={withBase(item.href)} title={labels.top}>
            <span class="side-nav-index">{String(index + 1).padStart(2, "0")}</span>
            <span class="side-nav-copy">
              <strong>{labels.top}</strong>
              <small>{labels.side}</small>
            </span>
            <span class="side-nav-short" aria-hidden="true">{labels.short}</span>
          </a>
        );
      })
    }
  </nav>
</aside>

<script>
  const menuToggle = document.querySelector(".menu-toggle");
  const sidebar = document.querySelector("#site-sidebar");
  const overlay = document.querySelector("[data-mobile-overlay]");
  const desktopMedia = window.matchMedia("(min-width: 1100px)");

  if (menuToggle instanceof HTMLButtonElement && sidebar instanceof HTMLElement && overlay instanceof HTMLElement) {
    const closeMobileSidebar = () => {
      sidebar.classList.remove("is-open");
      overlay.hidden = true;
      menuToggle.setAttribute("aria-expanded", "false");
    };

    const syncViewportState = () => {
      if (desktopMedia.matches) {
        closeMobileSidebar();
      }
    };

    menuToggle.addEventListener("click", () => {
      const next = sidebar.classList.toggle("is-open");
      overlay.hidden = !next;
      menuToggle.setAttribute("aria-expanded", String(next));
    });

    overlay.addEventListener("click", closeMobileSidebar);

    sidebar.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        closeMobileSidebar();
      });
    });

    if ("addEventListener" in desktopMedia) {
      desktopMedia.addEventListener("change", syncViewportState);
    }

    syncViewportState();
  }
</script>
