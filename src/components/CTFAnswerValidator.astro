---
interface Props {
  collection: string;
  challenge: string;
  passwordFormat: string;
  answerHashes: string[];
  hint?: string;
}

const { collection, challenge, passwordFormat, answerHashes, hint } = Astro.props;
const storageKey = `ctf:solved:${collection}:${challenge}`;
---

<section
  class="validator-card validator-card-compact"
  data-ctf-validator
  data-answer-hashes={JSON.stringify(answerHashes)}
  data-storage-key={storageKey}
>
  <div class="validator-head">
    <div>
      <p class="eyebrow">Validation</p>
      <h3>Validate Answer</h3>
    </div>
    <span class="validator-status-badge">Completed</span>
  </div>

  <form class="validator-form">
    <label class="sr-only" for="challenge-answer">Challenge answer</label>
    <input id="challenge-answer" name="answer" type="text" autocomplete="off" placeholder={passwordFormat} />
    <button class="button button-primary" type="submit" data-validator-button>Validate</button>
  </form>

  <p class="validator-state" data-validator-state>Ready.</p>

  {
    hint && (
      <details class="hint-box">
        <summary>Need a hint?</summary>
        <p>{hint}</p>
      </details>
    )
  }
</section>

<script>
  import { normalizeAndHashAnswer } from "../utils/ctfAnswer";
  import { readSolveRecord, writeSolveRecord } from "../utils/solveTracker";

  document.querySelectorAll("[data-ctf-validator]").forEach((card) => {
    const root = card;
    const form = root.querySelector(".validator-form");
    const input = form?.querySelector("input");
    const state = root.querySelector("[data-validator-state]");
    const button = root.querySelector("[data-validator-button]");
    const hashes = JSON.parse(root.getAttribute("data-answer-hashes") ?? "[]");
    const storageKey = root.getAttribute("data-storage-key");

    if (
      !(form instanceof HTMLFormElement) ||
      !(input instanceof HTMLInputElement) ||
      !(state instanceof HTMLElement) ||
      !(button instanceof HTMLButtonElement)
    ) {
      return;
    }

    const resetPending = () => {
      root.classList.remove("is-pending");
      button.disabled = false;
      button.textContent = "Validate";
    };

    const markPending = () => {
      root.classList.remove("is-error");
      root.classList.remove("is-solved");
      root.classList.add("is-pending");
      state.textContent = "Checking answer...";
      input.setAttribute("aria-invalid", "false");
      button.disabled = true;
      button.textContent = "Checking...";
    };

    const markSolved = () => {
      root.classList.remove("is-pending");
      root.classList.remove("is-error");
      root.classList.add("is-solved");
      state.textContent = "Correct answer. Challenge complete.";
      input.value = "Solved";
      input.disabled = true;
      input.setAttribute("aria-invalid", "false");
      button.disabled = true;
      button.textContent = "Completed";
    };

    const existingRecord = storageKey ? readSolveRecord(storageKey, localStorage) : null;

    if (existingRecord?.solved) {
      markSolved();
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const raw = input.value;
      if (!raw.trim()) {
        resetPending();
        root.classList.remove("is-solved");
        root.classList.add("is-error");
        state.textContent = "Enter an answer before validating.";
        input.setAttribute("aria-invalid", "true");
        return;
      }

      markPending();
      await new Promise((resolve) => requestAnimationFrame(() => resolve(undefined)));

      try {
        const timestamp = new Date().toISOString();
        const currentRecord = storageKey ? readSolveRecord(storageKey, localStorage) : null;
        const attempts = (currentRecord?.attempts ?? 0) + 1;
        const digest = await normalizeAndHashAnswer(raw);

        if (hashes.includes(digest)) {
          if (storageKey) {
            writeSolveRecord(
              storageKey,
              {
                solved: true,
                solvedAt: currentRecord?.solvedAt ?? timestamp,
                attempts,
                lastTriedAt: timestamp
              },
              localStorage
            );
          }
          markSolved();
          return;
        }

        resetPending();
        root.classList.remove("is-solved");
        root.classList.add("is-error");
        state.textContent = "Wrong answer. Try again.";
        input.setAttribute("aria-invalid", "true");

        if (storageKey) {
          writeSolveRecord(
            storageKey,
            {
              solved: false,
              solvedAt: currentRecord?.solvedAt,
              attempts,
              lastTriedAt: timestamp
            },
            localStorage
          );
        }
      } catch (error) {
        resetPending();
        root.classList.remove("is-solved");
        root.classList.add("is-error");
        state.textContent = "Validation failed in this browser session.";
        input.setAttribute("aria-invalid", "true");
      }
    });
  });
</script>
