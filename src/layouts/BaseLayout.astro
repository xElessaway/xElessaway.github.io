---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { siteMeta } from "../data/site";
import { withBase } from "../utils/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const { title = siteMeta.title, description = siteMeta.description, robots } = Astro.props;
const enableAnalytics = !robots?.includes("noindex");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={siteMeta.title} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    {
      enableAnalytics && (
        <script
          is:inline
          data-goatcounter="https://xelessaway.goatcounter.com/count"
          async
          src="https://gc.zgo.at/count.js"
        ></script>
      )
    }
    <title>{title}</title>
  </head>
  <body class="ops-root">
    <div class="scanline-overlay" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>
    <SiteHeader />
    <main class="page-main">
      <slot />
    </main>
    <SiteFooter />
    <dialog class="image-lightbox" data-image-lightbox aria-label="Expanded image viewer">
      <button class="image-lightbox-close" type="button" data-image-lightbox-close aria-label="Close image viewer">
        Close
      </button>
      <img class="image-lightbox-media" data-image-lightbox-media alt="" />
      <p class="image-lightbox-caption" data-image-lightbox-caption hidden></p>
    </dialog>

    <script is:inline>
      const lightbox = document.querySelector("[data-image-lightbox]");
      const lightboxMedia = lightbox?.querySelector("[data-image-lightbox-media]");
      const lightboxCaption = lightbox?.querySelector("[data-image-lightbox-caption]");
      const lightboxClose = lightbox?.querySelector("[data-image-lightbox-close]");

      const isZoomableImage = (element) =>
        element instanceof HTMLImageElement &&
        (element.matches(".prose img") || element.matches(".challenge-image") || element.hasAttribute("data-zoomable-image"));

      const setZoomableState = () => {
        document.querySelectorAll(".prose img, .challenge-image, img[data-zoomable-image]").forEach((element) => {
          if (element instanceof HTMLImageElement) {
            element.tabIndex = 0;
            element.setAttribute("role", "button");
            element.setAttribute("aria-haspopup", "dialog");
          }
        });
      };

      const openLightbox = (image) => {
        if (!(lightbox instanceof HTMLDialogElement) || !(lightboxMedia instanceof HTMLImageElement)) {
          return;
        }

        lightboxMedia.src = image.currentSrc || image.src;
        lightboxMedia.alt = image.alt || "";

        if (lightboxCaption instanceof HTMLElement) {
          const caption = image.alt?.trim();
          lightboxCaption.textContent = caption ?? "";
          lightboxCaption.hidden = !caption;
        }

        lightbox.showModal();
      };

      const closeLightbox = () => {
        if (lightbox instanceof HTMLDialogElement && lightbox.open) {
          lightbox.close();
        }
      };

      document.addEventListener("click", (event) => {
        const target = event.target;

        if (target instanceof Element) {
          const image = target.closest(".prose img, .challenge-image, img[data-zoomable-image]");

          if (isZoomableImage(image)) {
            event.preventDefault();
            openLightbox(image);
            return;
          }
        }

        if (target === lightbox || target === lightboxClose) {
          closeLightbox();
        }
      });

      document.addEventListener("keydown", (event) => {
        const target = event.target;

        if ((event.key === "Enter" || event.key === " ") && isZoomableImage(target)) {
          event.preventDefault();
          openLightbox(target);
        }
      });

      setZoomableState();
      document.addEventListener("astro:page-load", setZoomableState);
    </script>
  </body>
</html>
